{
  "name": "@crayfish-bot/desktop-pet",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop Pet - Electron client for crayfish-bot AI engine",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "generate-placeholder": "node scripts/generate-placeholder.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "ai-assistant"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.crayfish-bot.desktop-pet",
    "productName": "Crayfish Desktop Pet",
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
