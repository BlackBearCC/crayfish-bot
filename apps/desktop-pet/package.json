{
  "name": "@petclaw/desktop-pet",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop Pet - Electron client for Pet-Claw AI engine",
  "main": "electron/main.js",
  "scripts": {
    "start": "chcp 65001 >nul 2>&1 && electron .",
    "start:debug": "chcp 65001 >nul 2>&1 && electron . --prompt-debug",
    "start:verbose": "chcp 65001 >nul 2>&1 && electron . --verbose",
    "dev": "chcp 65001 >nul 2>&1 && electron . --dev",
    "dev:debug": "chcp 65001 >nul 2>&1 && electron . --dev --prompt-debug",
    "dev:verbose": "chcp 65001 >nul 2>&1 && electron . --dev --verbose",
    "generate-placeholder": "node scripts/generate-placeholder.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "ai-assistant"
  ],
  "license": "MIT",
  "author": "PetClaw",
  "dependencies": {
    "marked": "^17.0.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0",
    "petclaw": "workspace:*"
  },
  "build": {
    "appId": "com.petclaw.desktop-pet",
    "productName": "Pet-Claw Desktop",
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../dist",
        "to": "gateway/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../petclaw.mjs",
        "to": "gateway/petclaw.mjs"
      },
      {
        "from": "../../docs/reference/templates",
        "to": "gateway/docs/reference/templates",
        "filter": [
          "*.md"
        ]
      }
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
